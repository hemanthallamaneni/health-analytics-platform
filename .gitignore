# ============================================================================
# Python
# ============================================================================
# Bytecode caches generated by Python at runtime
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging artifacts
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
*.egg
.installed.cfg

# PyInstaller
*.manifest
*.spec

# ============================================================================
# Virtual environments
# ============================================================================
# uv creates .venv but also drops a .gitignore inside it as a safety net.
# We list it here too as primary defense.
.venv/
venv/
env/
ENV/
.python-venv/

# ============================================================================
# uv-specific
# ============================================================================
# uv keeps a global cache, but if it ever creates a local cache, ignore it.
.uv-cache/

# ============================================================================
# dbt
# ============================================================================
# dbt build artifacts and compiled SQL
target/
dbt_packages/
logs/
.user.yml

# dbt profiles file (contains warehouse credentials — NEVER commit)
profiles.yml

# ============================================================================
# Secrets and credentials
# ============================================================================
# Environment variable files (contain API tokens, database passwords, etc.)
.env
.env.*
!.env.example

# Generic credential files
*.pem
*.key
credentials.json
secrets.json
service-account*.json

# ============================================================================
# Data files
# ============================================================================
# Raw and processed data files — never commit health data to the repo.
# We keep the directory structure (.gitkeep files are tracked) but ignore
# everything else inside data/.
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Common data file extensions, in case any end up outside data/
*.csv
*.parquet
*.xml
*.json.gz
*.zip
# Exception: pyproject-related JSON-like files should still be tracked
!pyproject.toml

# ============================================================================
# Editors and IDEs
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ============================================================================
# Operating system
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================================================
# Jupyter / notebooks
# ============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# ============================================================================
# Testing and coverage
# ============================================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/

# ============================================================================
# Logs and temporary files
# ============================================================================
*.log
*.tmp
*.temp
*.bak
