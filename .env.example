SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
# Path to your unencrypted PKCS#8 RSA private key (.p8 file).
# Used by all Python scripts and dbt for key pair authentication.
# Snowflake is deprecating password auth (enforcement Aug-Oct 2026);
# key pair is the required replacement.
# Generate a key pair: https://docs.snowflake.com/en/user-guide/key-pair-auth
SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/your/snowflake_key.p8
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

OURA_PAT=
OURA_START_DATE=

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=
STRAVA_TOKEN_EXPIRES_AT=